# ============================================================
# .gitignore — ParkinsonTap-GP
# ============================================================

# Variables de entorno (nunca subir al repo)
.env

# ---- Backend (Java / Maven) ----
backend/target/
*.class
*.jar
*.war

# ---- Frontend (React / Node) ----
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local

# ---- ESP32 (PlatformIO) ----
esp32/.pio/
esp32/.pioenvs/
esp32/src/secrets.h

# ---- Docker ----
mosquitto/log/
mosquitto/data/

# ---- IDEs ----
.idea/
*.iml
.vscode/settings.json
.DS_Store
Thumbs.db
